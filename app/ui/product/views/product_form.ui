  <property name="styleSheet">
   <string notr="true">
/* ENTERPRISE FORM STYLING */
QDialog { background-color: #f4f6f8; font-family: 'Segoe UI', sans-serif; }
QLabel#lbl_main_title { font-size: 22px; font-weight: bold; color: #1a1a1a; padding: 10px 0px; }
QScrollArea { border: none; background-color: transparent; }
QWidget#scrollAreaWidgetContents { background-color: transparent; }
QGroupBox { background-color: #ffffff; border: 1px solid #e0e6ed; border-radius: 8px; margin-top: 30px; padding-top: 15px; font-size: 14px; }
QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; padding: 0 10px; color: #0056b3; font-weight: bold; font-size: 15px; top: 5px; left: 15px; }
QLabel { font-weight: 600; color: #4a5568; font-size: 13px; }
QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox, QTextEdit { padding: 8px 12px; border: 1px solid #ced4da; border-radius: 6px; background-color: #ffffff; font-size: 14px; color: #2d3748; min-height: 20px; }
QLineEdit:focus, QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus, QTextEdit:focus { border: 2px solid #007bff; background-color: #fff; }
QLineEdit:disabled, QComboBox:disabled { background-color: #e9ecef; color: #6c757d; }
QSpinBox::up-button, QSpinBox::down-button, QDoubleSpinBox::up-button, QDoubleSpinBox::down-button { width: 0px; border: none; }
QFrame#frame_footer { background-color: #ffffff; border-top: 1px solid #e0e6ed; padding: 10px; }
QPushButton { padding: 8px 16px; border-radius: 6px; font-weight: bold; font-size: 14px; }
QPushButton#btn_cancel { background-color: transparent; color: #4a5568; border: 1px solid #cbd5e0; }
QPushButton#btn_cancel:hover { background-color: #f1f3f5; }
QPushButton#btn_save { background-color: #007bff; color: white; border: none; }
QPushButton#btn_save:hover { background-color: #0069d9; }
/* STYLE CHO NÚT CỘNG (Thêm nhanh) */
QPushButton#btn_add_category, QPushButton#btn_add_supplier, QPushButton#btn_add_base_unit, QPushButton#btn_add_conversion_unit {
    padding: 4px; border-radius: 4px; background-color: #e9ecef; color: #495057; border: 1px solid #ced4da; font-size: 18px; font-weight: bold;
}
QPushButton#btn_add_category:hover, QPushButton#btn_add_supplier:hover, QPushButton#btn_add_base_unit:hover, QPushButton#btn_add_conversion_unit:hover {
    background-color: #007bff; color: white; border-color: #007bff;
}
   </string>
