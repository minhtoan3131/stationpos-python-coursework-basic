        border: none;
        background-color: transparent;
        gridline-color: #f8fafc;
    }
    QHeaderView::section {
        background-color: #ffffff;
        border: none;
        border-bottom: 2px solid #1e293b;
        font-weight: bold;
        padding: 5px;
        color: #475569;
    }

    /* Khu vực tính tiền */
    QFrame#frame_finance {
        background-color: #f8fafc;
        border-top: 2px dashed #cbd5e1;
        border-radius: 8px;
        padding: 10px;
    }

    QLabel#lbl_total_label { font-size: 16px; font-weight: bold; color: #475569; }
    QLabel#lbl_grand_total { font-size: 28px; font-weight: 900; color: #ef4444; }

    QLabel#lbl_cash_label { font-size: 15px; font-weight: bold; color: #1e293b; }
    QDoubleSpinBox#spn_cash_received {
        font-size: 20px;
        font-weight: bold;
        padding: 8px;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        color: #0f172a;
    }
    QDoubleSpinBox#spn_cash_received:focus { border: 2px solid #3b82f6; }

    QLabel#lbl_change_label { font-size: 15px; font-weight: bold; color: #64748b; }
    QLabel#lbl_change_due { font-size: 22px; font-weight: 900; color: #10b981; }

    /* Nút bấm */
    QPushButton {
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 14px;
    }
    QPushButton#btn_confirm {
        background-color: #10b981;
        color: white;
        border: none;
    }
    QPushButton#btn_confirm:hover { background-color: #059669; }

    QPushButton#btn_back {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        color: #475569;
    }
    QPushButton#btn_back:hover { background-color: #f8fafc; }
