   <string notr="true">
    /* Nền tảng Enterprise POS Dialog */
    QDialog {
        background-color: #f1f5f9;
        font-family: 'Segoe UI', sans-serif;
    }

    QFrame#frame_receipt {
        background-color: #ffffff;
