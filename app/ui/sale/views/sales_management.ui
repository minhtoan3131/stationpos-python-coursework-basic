  <property name="styleSheet">
   <string notr="true">
    /* Cấu trúc nền tảng Enterprise POS */
    QWidget {
        background-color: #f8fafc;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        font-size: 13px;
        color: #334155;
    }

    QFrame#frame_left, QFrame#frame_right {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
    }

    QLabel#lbl_title {
        font-size: 26px;
        font-weight: 800;
        color: #1e293b;
        padding-bottom: 5px;
    }

    QLabel#lbl_sub_left, QLabel#lbl_sub_right {
        font-size: 15px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        border-bottom: 2px solid #10b981;
        padding-bottom: 4px;
    }

    QLineEdit {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background-color: #ffffff;
    }
    QLineEdit:focus {
        border: 2px solid #10b981;
        background-color: #f0fdf4;
    }

    /* Table Styling */
    QTableWidget {
        background-color: #ffffff;
        border: none;
        gridline-color: #f1f5f9;
        selection-background-color: #ecfdf5;
        selection-color: #065f46;
        outline: none;
    }
    QHeaderView::section {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: bold;
        padding: 10px;
        border: none;
        border-bottom: 1px solid #e2e8f0;
    }

    /* Styling cho QSpinBox khi chèn vào bảng giỏ hàng */
    QSpinBox {
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        padding: 2px;
        background-color: #ffffff;
        min-width: 50px;
    }
    QSpinBox:focus {
        border: 1px solid #10b981;
        background-color: #f0fdf4;
    }

    QPushButton {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: bold;
    }

    QPushButton#btn_search { background-color: #64748b; color: white; }
    QPushButton#btn_add_to_cart { background-color: #10b981; color: white; border: none; }
    QPushButton#btn_add_to_cart:hover { background-color: #059669; }

    QPushButton#btn_cancel_bill { background-color: #ef4444; color: white; border: none; }
    QPushButton#btn_cancel_bill:hover { background-color: #dc2626; }

    QPushButton#btn_checkout { background-color: #059669; color: white; border: none; font-size: 16px; }
    QPushButton#btn_checkout:hover { background-color: #047857; }

    QLabel#lbl_total_bill {
        font-size: 32px;
        font-weight: 900;
        color: #ef4444;
    }

    QLabel#lbl_total_text {
        font-size: 14px;
        font-weight: bold;
        color: #64748b;
    }
   </string>
