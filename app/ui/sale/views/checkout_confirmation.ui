  <property name="styleSheet">
   <string notr="true">
    /* Nền tảng Enterprise POS Dialog Hiện đại */
    QDialog {
        background-color: #e2e8f0;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
    }

    QFrame#frame_receipt {
        background-color: #ffffff;
        border: none;
        border-radius: 12px;
        border-bottom: 3px solid #cbd5e1;
    }

    QLabel#lbl_invoice_title {
        font-size: 26px;
        font-weight: 900;
        color: #0f172a;
        letter-spacing: 1px;
    }

    QLabel#lbl_invoice_id {
        font-size: 14px;
        font-weight: 700;
        color: #64748b;
        background-color: #f1f5f9;
        padding: 4px 10px;
        border-radius: 4px;
    }

    QLabel#lbl_store_info, QLabel#lbl_date {
        color: #475569;
        font-size: 14px;
    }

    /* Bảng chi tiết Bill */
    QTableWidget {
        border: none;
        background-color: transparent;
        gridline-color: #e2e8f0;
    }
    QTableWidget::item {
        padding: 8px 4px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* STYLE CHO HEADER CỦA BẢNG ĐƯỢC CHỈNH LẠI ĐỂ BẮT BUỘC HIỂN THỊ */
    QHeaderView {
        background-color: #ffffff;
        border: none;
    }
    QHeaderView::section {
        background-color: #ffffff;
        border: none;
        border-bottom: 2px solid #cbd5e1;
        font-weight: 800;
        font-size: 13px;
        color: #334155;
        text-transform: uppercase;
        padding: 8px 4px;
        min-height: 35px;
    }

    /* Khu vực tính tiền */
    QFrame#frame_finance {
        background-color: #f8fafc;
        border-top: 2px dashed #94a3b8;
        border-radius: 0px 0px 12px 12px;
        padding: 20px;
    }

    QLabel#lbl_total_label { font-size: 16px; font-weight: 700; color: #475569; }
    QLabel#lbl_grand_total { font-size: 32px; font-weight: 900; color: #1e293b; }

    QLabel#lbl_cash_label { font-size: 15px; font-weight: 700; color: #334155; }
    QDoubleSpinBox#spn_cash_received {
        font-size: 22px;
        font-weight: 800;
        padding: 10px;
        border: 2px solid #cbd5e1;
        border-radius: 8px;
        color: #0f172a;
        background-color: #ffffff;
    }
    QDoubleSpinBox#spn_cash_received:focus {
        border: 2px solid #f59e0b;
        background-color: #fffbeb;
    }

    QLabel#lbl_change_label { font-size: 15px; font-weight: 700; color: #64748b; }
    QLabel#lbl_change_due { font-size: 24px; font-weight: 900; color: #10b981; }

    /* ComboBox Phương thức TT */
    QComboBox {
        padding: 10px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background-color: #ffffff;
        font-size: 14px;
        font-weight: 600;
        color: #334155;
    }

    /* Nút bấm */
    QPushButton {
        padding: 14px 24px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 15px;
        letter-spacing: 0.5px;
    }
    QPushButton#btn_confirm {
        background-color: #10b981;
        color: white;
        border: none;
    }
    QPushButton#btn_confirm:hover { background-color: #059669; }

    QPushButton#btn_back {
        background-color: transparent;
        border: 2px solid #cbd5e1;
        color: #475569;
    }
    QPushButton#btn_back:hover {
        background-color: #f1f5f9;
        border-color: #94a3b8;
    }
   </string>
