    QLineEdit, QComboBox {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background-color: #ffffff;
    }
    QLineEdit:focus {
        border: 2px solid #3b82f6;
        background-color: #f0f9ff;
    }

    QTableWidget {
        background-color: #ffffff;
        border: none;
        gridline-color: #f1f5f9;
        selection-background-color: #e0f2fe;
        selection-color: #0369a1;
        outline: none;
    }
    QHeaderView::section {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: bold;
        padding: 10px;
        border: none;
        border-bottom: 1px solid #e2e8f0;
    }

    QPushButton {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: bold;
    }

    QPushButton#btn_search { background-color: #64748b; color: white; }
    QPushButton#btn_import_action { background-color: #3b82f6; color: white; border: none; }
    QPushButton#btn_import_action:hover { background-color: #2563eb; }
    QPushButton#btn_clear_all { background-color: #ef4444; color: white; border: none; }
    QPushButton#btn_clear_all:hover { background-color: #dc2626; }
    QPushButton#btn_save_all { background-color: #10b981; color: white; border: none; }
    QPushButton#btn_save_all:hover { background-color: #059669; }
    QPushButton#btn_add_supplier { padding: 8px; }

    QLabel#lbl_total_value {
        font-size: 26px;
        font-weight: 900;
        color: #ef4444;
    }
