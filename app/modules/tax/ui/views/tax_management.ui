  <property name="styleSheet">
   <string notr="true">
    /* Hệ thống Stylesheet đồng bộ Enterprise POS */
    QWidget {
        background-color: #f8fafc;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        font-size: 13px;
        color: #334155;
    }

    QFrame.section-frame, QFrame#frame_tax_history_detail {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
    }

    QFrame.kpi-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
    }
    QLabel.kpi-label {
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
    }
    QLabel.kpi-value {
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
    }

    QLabel#lbl_title {
        font-size: 26px;
        font-weight: 800;
        color: #1e293b;
        padding-bottom: 5px;
    }

    QLabel.section-title {
        font-size: 15px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        border-bottom: 2px solid #10b981;
        padding-bottom: 4px;
    }

    QLabel#lbl_sub_history_tax {
        font-size: 15px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        border-bottom: 2px solid #3b82f6;
        padding-bottom: 4px;
    }

    QDoubleSpinBox, QComboBox {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background-color: #ffffff;
        font-weight: bold;
    }
    QDoubleSpinBox:focus, QComboBox:focus {
        border: 2px solid #10b981;
        background-color: #f0fdf4;
    }

    QTableWidget {
        background-color: #ffffff;
        border: none;
        gridline-color: #f1f5f9;
        outline: none;
    }
    QHeaderView::section {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: bold;
        padding: 6px;
        border: none;
        border-bottom: 1px solid #e2e8f0;
    }

    QProgressBar {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        background-color: #ffffff;
        text-align: center;
        color: #0f172a;
        font-weight: bold;
        height: 28px;
    }

    QPushButton {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: bold;
        border: none;
    }

    QPushButton#btn_apply_config {
        background-color: #10b981;
        color: white;
    }
    QPushButton#btn_apply_config:hover {
        background-color: #059669;
    }

    QPushButton#btn_close_ledger {
        background-color: #ef4444;
        color: white;
    }
    QPushButton#btn_close_ledger:hover {
        background-color: #dc2626;
    }

    QPushButton#btn_print_ledger { background-color: #0ea5e9; color: white; }
    QPushButton#btn_export_ledger_excel { background-color: #0f766e; color: white; }

    QTabWidget::tab-bar { alignment: left; }
    QTabWidget::pane { border: 1px solid #e2e8f0; background: #ffffff; border-radius: 8px; }
    QTabBar::tab {
        background: #e2e8f0; color: #475569; padding: 10px 20px; font-weight: bold;
        border-top-left-radius: 6px; border-top-right-radius: 6px; margin-right: 4px;
    }
    QTabBar::tab:selected { background: #ffffff; color: #10b981; border-bottom: 3px solid #10b981; }
   </string>
