   <string notr="true">
    QWidget#TaxManagementWidget { background-color: #f1f5f9; font-family: 'Segoe UI', sans-serif; }
    QScrollArea { border: none; background-color: transparent; }
    #scrollContents { background-color: #f1f5f9; }

    QFrame.kpi-card { background-color: #ffffff; border-radius: 12px; }
