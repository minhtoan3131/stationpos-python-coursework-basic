    QLabel.kpi-value { font-size: 24px; font-weight: 800; color: #0f172a; }

    QProgressBar {
        border: 1px solid #e2e8f0; border-radius: 10px; background-color: #ffffff;
        text-align: center; color: #0f172a; font-weight: bold; height: 28px;
    }

    QFrame.section-frame { background-color: #ffffff; border-radius: 12px; }
    QLabel.section-title { font-size: 17px; font-weight: 700; color: #1e293b; padding-bottom: 8px; border-bottom: 1px solid #f1f5f9; }

    QTableWidget { border: none; gridline-color: #f1f5f9; background-color: white; }
    QHeaderView::section { background-color: #f8fafc; padding: 10px; font-weight: bold; border: none; border-bottom: 2px solid #e2e8f0; color: #475569; }

    QDoubleSpinBox, QComboBox {
        padding: 8px; border: 1px solid #cbd5e1; border-radius: 6px; background: white; font-weight: bold;
    }
    QPushButton#btn_apply_config {
        background-color: #3b82f6; color: white; border-radius: 6px; padding: 10px; font-weight: 800;
    }
    QPushButton#btn_apply_config:hover { background-color: #2563eb; }

    /* Style cho danh sách xổ xuống của ComboBox */
