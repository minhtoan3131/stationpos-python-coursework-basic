   <string notr="true">
/* ENTERPRISE MODERN STYLE */
QWidget#ProductManagementWidget {
    background-color: #fcfcfc;
    font-family: 'Segoe UI', sans-serif;
}

QFrame#frame_container {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
}

QLabel#lbl_title {
    font-size: 26px;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 10px;
}

QLineEdit#txt_search_keyword {
    border: 2px solid #edeff2;
    border-radius: 8px;
    padding: 10px 15px;
    background-color: #f4f6f8;
    font-size: 14px;
}
QLineEdit#txt_search_keyword:focus {
    border: 2px solid #007bff;
    background-color: #ffffff;
}

QPushButton {
    border-radius: 8px;
    padding: 10px 20px;
    font-weight: 600;
    font-size: 13px;
    color: white;
}

QPushButton#btn_search_products { background-color: #007bff; }
QPushButton#btn_search_products:hover { background-color: #0069d9; }
QPushButton#btn_create_product { background-color: #28a745; }
QPushButton#btn_create_product:hover { background-color: #218838; }
QPushButton#btn_update_product { background-color: #ffc107; color: #212529; }
QPushButton#btn_update_product:hover { background-color: #e0a800; }
QPushButton#btn_delete_product { background-color: #dc3545; }
QPushButton#btn_delete_product:hover { background-color: #c82333; }
QPushButton#btn_refresh_products {
    background-color: transparent;
    color: #6c757d;
    border: 1px solid #ced4da;
}
QPushButton#btn_refresh_products:hover { background-color: #f8f9fa; }

QTableWidget {
    border: none;
    gridline-color: #f1f1f1;
    alternate-background-color: #f9fafb;
    selection-background-color: #e7f3ff;
    selection-color: #0056b3;
}
QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid #f1f1f1;
    color: #4a5568;
}
