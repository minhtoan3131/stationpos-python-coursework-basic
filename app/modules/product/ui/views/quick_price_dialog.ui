    padding: 6px 12px;
    font-size: 14px;
    color: #0f172a;
    background-color: #f8fafc;
}
QDoubleSpinBox:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}
QPushButton {
    padding: 8px 18px;
    font-size: 13px;
    font-weight: bold;
    border-radius: 6px;
}
QPushButton#btn_save {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
}
QPushButton#btn_save:hover {
