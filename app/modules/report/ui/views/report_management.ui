<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ReportManagementWidget</class>
 <widget class="QWidget" name="ReportManagementWidget">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1400</width>
    <height>950</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Báo cáo &amp; Thống kê Hệ thống</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Tổng thể Dashboard */
    QWidget#ReportManagementWidget {
        background-color: #e2e8f0;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
    }

    QScrollArea {
        border: none;
        background-color: transparent;
    }

    #scrollContents {
        background-color: #e2e8f0;
    }

    /* Thẻ chỉ số (KPI Cards) &amp; Nhóm phân loại */
    QFrame.kpi-card {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        min-height: 115px;
    }

    QLabel#lbl_title_main {
        font-size: 26px;
        font-weight: 800;
        color: #0f172a;
    }

    QLabel.kpi-group-title {
        font-size: 14px;
        font-weight: 700;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding-left: 2px;
    }

    QLabel.kpi-label {
        font-size: 13px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
    }

    QLabel.kpi-value {
        font-size: 24px;
        font-weight: 800;
    }

    QLabel.kpi-desc {
        font-size: 12px;
        color: #64748b;
        font-weight: 500;
    }

    /* Đổ màu chuyên biệt cho từng chỉ số mới */
    QLabel#val_gross_revenue { color: #0284c7; }   /* Xanh dương nhạt - Doanh thu thô */
    QLabel#val_cancelled_value { color: #ef4444; }  /* Đỏ - Tiền hủy hoàn */
    QLabel#val_net_revenue { color: #10b981; }      /* Xanh lá - Thực thu sạch */
    QLabel#val_order_stats { color: #8b5cf6; }      /* Tím - Phễu đơn hàng */

    QLabel#val_cogs { color: #f59e0b; }             /* Cam - Giá vốn */
    QLabel#val_gross_profit { color: #3b82f6; }     /* Xanh Lam - Lợi nhuận gộp */
    QLabel#val_variance_garbage { color: #64748b; } /* Xám - Tiền dọn rác kho */
    QLabel#val_net_profit { color: #0d9488; }       /* Xanh ngọc - Lợi nhuận thực */

    /* Khu vực Biểu đồ &amp; Bảng */
    QFrame#frame_revenue_trend, QFrame#frame_top_products, QFrame#frame_history, QFrame#frame_inventory, QFrame#frame_diagram {
        background-color: #ffffff;
        border-radius: 12px;
        margin-bottom: 5px;
    }

    QFrame#frame_revenue_trend, QFrame#frame_top_products {
        padding: 15px;
    }

    QLabel.section-title {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        padding: 10px 15px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Bộ lọc (Filters) */
    QPushButton.btn-filter {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 8px 15px;
        font-weight: 600;
        color: #475569;
    }
    QPushButton.btn-filter:checked {
        background-color: #3b82f6;
        color: white;
    }

    QPushButton#btn_run_filter {
        background-color: #0f172a;
        color: white;
        border-radius: 6px;
        padding: 8px 20px;
        font-weight: 700;
    }

    /* Ô chọn ngày tháng (Date Editors) */
    QDateEdit {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 6px 26px 6px 10px;
        font-weight: 600;
        color: #475569;
        max-width: 110px;
    }
    QDateEdit:hover {
        border-color: #94a3b8;
    }
    QDateEdit:focus {
        border-color: #3b82f6;
    }
    QDateEdit::drop-down {
        subcontrol-origin: padding;
        subcontrol-position: top right;
        width: 20px;
        border: none;
    }
    QDateEdit::down-arrow {
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 5px solid #475569;
        width: 0;
        height: 0;
    }

    QTableWidget {
        border: none;
        gridline-color: #f1f5f9;
        background-color: white;
    }
    QHeaderView::section {
        background-color: #f8fafc;
        padding: 10px;
        font-weight: bold;
        border: none;
        border-bottom: 2px solid #e2e8f0;
        color: #475569;
    }

    QTableWidget {
        font-size: 14px;        /* Tăng kích thước chữ nội dung lên 14px (Mặc định thường là 12px) */
    }

   </string>
  </property>
