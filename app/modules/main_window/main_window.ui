    <height>900</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>StationPOS - Hệ thống Quản lý văn phòng phẩm</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Tổng thể hệ thống */
    QMainWindow {
        background-color: #f8fafc;
    }

    /* Sidebar Side - Modern Enterprise Design với Gradient nền */
    QFrame#frame_sidebar {
        /* Chuyển sắc từ Trắng (trên) xuống Xám Xanh đậm dần (dưới) */
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #ffffff, stop:1 #cbd5e1);
        border-right: 1px solid #e1e7ef;
        min-width: 280px;
        max-width: 280px;
    }

    /* Header Logo Area - Gradient và Modern */
    QLabel#lbl_logo {
        color: #ffffff;
        font-size: 20px;
        font-weight: 700;
        padding: 20px;
        background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #10b981, stop:1 #064e3b);

        /* Gradient xanh tím enterprise */
        border-bottom: 1px solid #e1e7ef;
    }

    /* List Menu Điều hướng - Cải tiến với border-radius và spacing */
    QListWidget#sidebar_menu {
        background-color: transparent;
        border: none;
        outline: none;
        padding-top: 20px;
        padding-bottom: 20px;
    }
    QListWidget#sidebar_menu::item {
        color: #374151;
        padding: 16px 24px;
        border-left: 4px solid transparent;
        font-size: 14px;
        font-weight: 500;
        border-radius: 8px;
        /* Thêm bo góc hiện đại */
        margin: 4px 12px;
        /* Tăng margin để không chạm viền */
    }
    QListWidget#sidebar_menu::item:hover {
        background-color: #f3f4f6;
        color: #1f2937;
        border-radius: 8px;
    }
    QListWidget#sidebar_menu::item:selected {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                    stop:0 #dbeafe, stop:1 #bfdbfe);
        /* Gradient xanh nhạt */
        color: #1e40af;
        border-left: 4px solid #3b82f6;
        font-weight: 600;
        border-radius: 8px;
    }

    /* Scrollbar cho QListWidget - Làm thanh cuộn đẹp hơn và dài hơn */
    QListWidget#sidebar_menu QScrollBar:vertical {
        background: transparent;
        width: 8px;
        border-radius: 4px;
    }
    QListWidget#sidebar_menu QScrollBar::handle:vertical {
        background: #cbd5e1;
        border-radius: 4px;
        min-height: 40px; /* Tăng min-height để thanh cuộn dài hơn */
    }
    QListWidget#sidebar_menu QScrollBar::handle:vertical:hover {
        background: #94a3b8;
    }
    QListWidget#sidebar_menu QScrollBar::add-line:vertical,
    QListWidget#sidebar_menu QScrollBar::sub-line:vertical {
        border: none;
        background: none;
    }

    /* Vùng hiển thị nội dung bên phải */
    QStackedWidget#content_stack {
        background-color: #f8fafc;
    }

    /* Footer Sidebar */
    QLabel#lbl_version {
        color: #9ca3af;
        font-size: 11px;
        padding: 16px;
        background-color: transparent;
        border-top: 1px solid #e5e7eb;
    }
   </string>
  </property>
