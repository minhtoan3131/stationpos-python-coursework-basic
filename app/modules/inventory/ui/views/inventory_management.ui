  <property name="styleSheet">
   <string notr="true">
    /* Cấu trúc nền tảng Enterprise */
    QWidget {
        background-color: #f8fafc;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        font-size: 13px;
        color: #334155;
    }

    QFrame#frame_left, QFrame#frame_right {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
    }

    QLabel#lbl_title {
        font-size: 26px;
        font-weight: 800;
        color: #1e293b;
        padding-bottom: 5px;
    }

    QLabel#lbl_sub_left, QLabel#lbl_sub_right, QLabel#lbl_sub_history {
        font-size: 15px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        border-bottom: 2px solid #3b82f6;
        padding-bottom: 4px;
    }

    QLineEdit, QComboBox, QDateEdit {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background-color: #ffffff;
    }
    QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
        border: 2px solid #3b82f6;
        background-color: #f0f9ff;
    }

    QTableWidget {
        background-color: #ffffff;
        border: none;
        gridline-color: #f1f5f9;
        selection-background-color: #e0f2fe;
        selection-color: #0369a1;
        outline: none;
    }
    QHeaderView::section {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: bold;
        padding: 10px;
        border: none;
        border-bottom: 1px solid #e2e8f0;
    }

    QPushButton {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: bold;
    }

    QPushButton#btn_search, QPushButton#btn_filter_po { background-color: #64748b; color: white; border: none; }
    QPushButton#btn_search:hover, QPushButton#btn_filter_po:hover { background-color: #475569; }

    QPushButton#btn_reset_filter_po { background-color: #e2e8f0; color: #475569; border: 1px solid #cbd5e1; }
    QPushButton#btn_reset_filter_po:hover { background-color: #cbd5e1; }

    QPushButton#btn_import_action { background-color: #3b82f6; color: white; border: none; }
    QPushButton#btn_import_action:hover { background-color: #2563eb; }

    QPushButton#btn_clear_all, QPushButton#btn_cancel_po { background-color: #ef4444; color: white; border: none; }
    QPushButton#btn_clear_all:hover, QPushButton#btn_cancel_po:hover { background-color: #dc2626; }

    QPushButton#btn_save_all { background-color: #10b981; color: white; border: none; }
    QPushButton#btn_save_all:hover { background-color: #059669; }

    QPushButton#btn_export_po_excel { background-color: #0f766e; color: white; border: none; }
    QPushButton#btn_export_po_excel:hover { background-color: #115e59; }

    QLabel#lbl_total_value, QLabel#lbl_detail_total_value {
        font-size: 26px;
        font-weight: 900;
        color: #ef4444;
    }

    /* Giao diện Tab Widget hiện đại */
    QTabWidget::tab-bar {
        alignment: left;
    }
    QTabWidget::pane {
        border: 1px solid #e2e8f0;
        background: #ffffff;
        border-radius: 8px;
    }
    QTabBar::tab {
        background: #e2e8f0;
        color: #475569;
        padding: 10px 20px;
        font-weight: bold;
        border-top-left-radius: 6px;
        border-top-right-radius: 6px;
        margin-right: 4px;
    }
    QTabBar::tab:selected {
        background: #ffffff;
        color: #3b82f6;
        border-bottom: 3px solid #3b82f6;
    }

    QTableWidget {
        font-size: 14px;        /* Tăng kích thước chữ nội dung lên 14px (Mặc định thường là 12px) */
    }
   </string>
