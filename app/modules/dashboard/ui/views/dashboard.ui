    <width>1400</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Trung tâm Điều phối Hành động</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Thiết kế Enterprise hiện đại và đồng bộ toàn hệ thống */
    QWidget#HomeWelcomeWidget {
        background-color: #f8fafc;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        color: #334155;
    }

    /* Thẻ chỉ số động (Live Status Cards) */
    QFrame.live-badge {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding-left: 12px;
    }
    QLabel.badge-title {
        font-size: 13px;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
    }
    QLabel.badge-value {
        font-size: 26px;
        font-weight: 800;
    }

    /* Màu sắc động cho từng loại chỉ số badge */
    QLabel#val_badge_stock { color: #ef4444; }     /* Cảnh báo kho màu đỏ */
    QLabel#val_badge_tax { color: #f59e0b; }       /* Tiến trình thuế màu cam */
    QLabel#val_badge_orders { color: #10b981; }    /* Đơn hàng màu xanh lá */

    /* Khung nội dung chính phía dưới */
    QFrame.panel-container {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
    }

    QLabel.block-title {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        padding-bottom: 8px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Thiết kế danh sách cảnh báo hành động liên kết sâu (Left Panel) */
    QListWidget#list_actionable_alerts {
        border: none;
        background-color: transparent;
        font-size: 13px;
        outline: none;
    }
    QListWidget#list_actionable_alerts::item {
        background-color: #fff1f2;
        border: 1px solid #ffe4e6;
        border-left: 5px solid #ef4444; /* Vạch đỏ nhấn mạnh hành động */
        border-radius: 6px;
        padding: 14px 16px;
        margin-bottom: 10px;
        color: #1e293b;
    }
    QListWidget#list_actionable_alerts::item:hover {
        background-color: #ffe4e6;
    }

    /* Thiết kế dòng thời gian hoạt động gần đây (Right Panel - Audit Feed) */
    QListWidget#list_live_feed {
        border: none;
        background-color: transparent;
        font-size: 13px;
        outline: none;
    }
    QListWidget#list_live_feed::item {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-left: 4px solid #3b82f6; /* Vạch xanh dương dòng thời gian */
        border-radius: 6px;
        padding: 12px 14px;
        margin-bottom: 8px;
        color: #475569;
    }
    QListWidget#list_live_feed::item:hover {
        background-color: #f1f5f9;
    }

    QLabel {
        font-size: 14px;
    }
   </string>
  </property>
