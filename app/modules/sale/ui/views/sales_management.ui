<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>SalesManagementWidget</class>
 <widget class="QWidget" name="SalesManagementWidget">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1400</width>
    <height>850</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Bán hàng tại quầy (POS)</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Nền tảng Enterprise POS */
    QWidget {
        background-color: #f8fafc;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        font-size: 13px;
        color: #334155;
    }

    QFrame#frame_left, QFrame#frame_right {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
    }

    QLabel#lbl_title {
        font-size: 26px;
        font-weight: 800;
        color: #1e293b;
        padding-bottom: 5px;
    }

    /* Tiêu đề các cột/khung */
    QLabel#lbl_sub_left, QLabel#lbl_sub_right, QLabel#lbl_sub_history_sales {
        font-size: 15px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        border-bottom: 2px solid #10b981;
        padding-bottom: 4px;
    }

    /* Riêng tab Lịch sử dùng màu xanh dương để phân biệt với POS */
    QLabel#lbl_sub_history_sales {
        border-bottom: 2px solid #3b82f6;
    }

    QLineEdit, QComboBox, QDateEdit {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background-color: #ffffff;
    }
    QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
        border: 2px solid #10b981;
        background-color: #f0fdf4;
    }

    /* Table Styling */
    QTableWidget {
        background-color: #ffffff;
        border: none;
        gridline-color: #f1f5f9;
        selection-background-color: #ecfdf5;
        selection-color: #065f46;
        outline: none;
    }
    QHeaderView::section {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: bold;
        padding: 10px;
        border: none;
        border-bottom: 1px solid #e2e8f0;
    }

    QPushButton {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: bold;
    }

    /* Buttons cho POS (Màu xanh lá) */
    QPushButton#btn_search { background-color: #64748b; color: white; }
    QPushButton#btn_add_to_cart { background-color: #10b981; color: white; border: none; }
    QPushButton#btn_checkout { background-color: #059669; color: white; border: none; font-size: 16px; }

    /* Buttons cho Lịch sử (Màu xanh dương) */
    QPushButton#btn_filter_invoice { background-color: #3b82f6; color: white; border: none; }
    QPushButton#btn_reprint_invoice { background-color: #0ea5e9; color: white; border: none; }
    QPushButton#btn_export_invoice_excel { background-color: #0f766e; color: white; border: none; }

    /* Button Hủy (Màu đỏ) */
    QPushButton#btn_cancel_bill, QPushButton#btn_cancel_invoice { background-color: #ef4444; color: white; border: none; }

    QLabel#lbl_total_bill, QLabel#lbl_detail_total_value {
        font-size: 32px;
        font-weight: 900;
        color: #ef4444;
    }

    /* Giao diện Tab Widget hiện đại */
    QTabWidget::tab-bar { alignment: left; }
    QTabWidget::pane { border: 1px solid #e2e8f0; background: #ffffff; border-radius: 8px; }
    QTabBar::tab {
        background: #e2e8f0; color: #475569; padding: 10px 20px; font-weight: bold;
        border-top-left-radius: 6px; border-top-right-radius: 6px; margin-right: 4px;
    }
    QTabBar::tab:selected { background: #ffffff; color: #10b981; border-bottom: 3px solid #10b981; }

    /* Tab Lịch sử có thể đổi màu indicator sang xanh dương nếu muốn bằng code, ở đây mặc định theo POS */
   </string>
