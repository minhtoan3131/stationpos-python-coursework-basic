  <property name="styleSheet">
   <string notr="true">
    /* Lớp nền mờ phủ toàn màn hình */
    QDialog {
        background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 rgba(241, 245, 249, 0.90), stop:1 rgba(226, 232, 240, 0.95));
    }

    /* Cấu trúc Khung trung tâm (Card) được chia đôi */
    QFrame#center_card {
        background-color: transparent;
        border: 1px solid #cbd5e1;
        border-radius: 16px;
    }

    /* Khung Thương hiệu bên trái */
    QFrame#frame_brand_left {
        background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #10b981, stop:1 #064e3b);
        border-top-left-radius: 15px;
        border-bottom-left-radius: 15px;
        border: none;
    }

    /* Khung Nhập liệu bên phải */
    QFrame#frame_login_right {
        background-color: #ffffff;
        border-top-right-radius: 15px;
        border-bottom-right-radius: 15px;
        border: none;
    }

    QLabel#lbl_brand_station_pos {
        font-size: 42px;
        font-weight: bold;
        color: #ffffff;
        letter-spacing: 1px;
        background-color: transparent;
    }

    QLabel#lbl_title {
        color: #1e293b;
        font-size: 24px;
        font-weight: bold;
        border: none;
        background-color: transparent;
    }

    QLineEdit#txt_pin {
        background-color: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        padding: 0px 15px;
        font-size: 20px;
        color: #0f172a;
    }
    QLineEdit#txt_pin:focus {
        border: 2px solid #0284c7;
        background-color: #ffffff;
    }

    QPushButton#btn_unlock {
        background-color: #0284c7;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: bold;
    }
    QPushButton#btn_unlock:hover {
        background-color: #0369a1;
    }
    QPushButton#btn_unlock:pressed {
        background-color: #075985;
    }

    QPushButton#btn_forgot {
        background-color: transparent;
        border: none;
        color: #64748b;
        font-size: 13px;
        font-weight: 500;
    }
    QPushButton#btn_forgot:hover {
        color: #0284c7;
        text-decoration: underline;
    }
   </string>
