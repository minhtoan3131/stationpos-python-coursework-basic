  <property name="styleSheet">
   <string>
QWidget#Form, QWidget#scrollAreaWidgetContents {
    background-color: #f8fafc;
    font-family: 'Segoe UI', 'Roboto', sans-serif;
    color: #334155;
}

/* Tùy chỉnh thanh cuộn cho hiện đại */
QScrollArea {
    border: none;
    background-color: transparent;
}
QScrollBar:vertical {
    border: none;
    background-color: transparent;
    width: 8px;
    margin: 0px 0px 0px 0px;
}
QScrollBar::handle:vertical {
    background-color: #cbd5e1;
    min-height: 30px;
    border-radius: 4px;
}
QScrollBar::handle:vertical:hover {
    background-color: #94a3b8;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QFrame {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
}

QLabel {
    border: none;
    background: transparent;
    font-size: 16px;
    color: #334155;
}

/* Các tiêu đề được đồng bộ hóa từ home_welcome.ui */
QLabel#label_title {
    font-size: 26px;
    font-weight: 800;
    color: #0f172a;
}
QLabel#label_subtitle {
    font-size: 14px;
    color: #64748b;
}

QLabel#label_store_title, QLabel#label_sec_title, QLabel#label_backup_title {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
}

QLabel#label_store_sub, QLabel#label_sec_sub, QLabel#label_backup_sub {
    font-size: 13px;
    font-weight: 600;
    color: #64748b;
}

QLineEdit, QComboBox, QTimeEdit {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px 14px;
    background-color: #f8fafc;
    font-size: 14px;
    color: #1e293b;
    min-height: 20px;
}

QLineEdit:focus, QComboBox:focus, QTimeEdit:focus {
    border: 2px solid #3b82f6;
    background-color: #ffffff;
}

QPushButton {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 12px 24px;
    background-color: #ffffff;
    font-weight: 600;
    font-size: 14px;
    color: #475569;
}

QPushButton:hover {
    background-color: #f1f5f9;
}

QPushButton#btn_save_bill {
    background-color: #3b82f6;
    color: white;
    border: none;
}
QPushButton#btn_save_bill:hover {
    background-color: #2563eb;
}

QPushButton#btn_save_security {
    background-color: #0f172a;
    color: white;
    border: none;
}
QPushButton#btn_save_security:hover {
    background-color: #1e293b;
}

QPushButton#btn_manual_backup {
    background-color: #10b981;
    color: white;
    border: none;
}
QPushButton#btn_manual_backup:hover {
    background-color: #059669;
}

QPushButton#btn_save_backup_config {
    background-color: #3b82f6;
    color: white;
    border: none;
}
QPushButton#btn_save_backup_config:hover {
    background-color: #2563eb;
}

QComboBox::drop-down {
    border: none;
}

QCheckBox::indicator {
    width: 24px;
    height: 24px;
}
   </string>
